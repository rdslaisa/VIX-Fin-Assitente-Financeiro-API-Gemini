# Configuração de Exemplo - VIX Fin
# Copie este arquivo para .env e customize as variáveis

# Ambiente
FLASK_ENV=development
FLASK_DEBUG=True

# Chat com IA (Atena) - obtenha uma chave gratuita em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Servidor
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# API
API_TIMEOUT=30
API_RETRIES=3

# Dados
DEFAULT_CURRENCY=BRL
DEFAULT_PERIOD=1y

# Logging
LOG_LEVEL=INFO
